{%- comment -%}
  Snippet: knr-product-labels
  Renders product labels stored in metafield `product_info.product_labels` as a block.
  Usage: {% render 'knr-product-labels', block: block %}
{%- endcomment -%}

{%- assign labels_field = null -%}
{%- if product
  and product.metafields
  and product.metafields.product_info
  and product.metafields.product_info.product_labels != null
-%}
  {%- assign labels_field = product.metafields.product_info.product_labels -%}
{%- endif -%}

{%- if labels_field != null -%}
  {%- if labels_field.value != null -%}
    {%- assign labels = labels_field.value -%}
  {%- else -%}
    {%- assign labels = labels_field -%}
  {%- endif -%}
{%- else -%}
  {%- assign labels = null -%}
{%- endif -%}

{%- if labels != blank -%}
  <div
    class="knr-product-labels"
    {% if block and block.shopify_attributes %}
      {{- block.shopify_attributes -}}
    {% endif %}
  >
    {% for label in labels %}
      <span class="knr-product-label">{{ label }}</span>
    {% endfor %}
  </div>

  <style>
    .knr-product-labels {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      padding: 0;
    }
    .knr-product-label {
      border: 0.5px solid #000000;
      padding: 0.4rem;
      font-family: 'Inter', sans-serif;
      font-optical-sizing: auto;
      font-style: normal;
      font-size: 1.2rem;
      text-transform: uppercase;
      font-weight: 400;
      letter-spacing: -0.24px;
      border-radius: 0.2rem;
      line-height: 100%;
    }
  </style>
{%- endif -%}
