{% comment %}
  KNR — "Ce que disent nos clients" section
  - width mode: full or theme width
  - padding top/bottom/left/right (range)
  - background & text colors
  - title + description
  - before / after images with draggable slider
  - repeatable review blocks: rating (1-5), person, comment, item spacing
  - section-level text alignment for review text
{% endcomment %}

<section
  id="knr-what-customers-{{ section.id }}"
  class="knr-what-customers section-{{ section.id }}-padding"
  style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
>
  {% if section.settings.width_mode == 'theme' %}
    <div class="page-width">
  {% endif %}

  <div class="knr-what-customers__header">
    {% if section.settings.title != blank %}
      <h2 class="knr-what-customers__title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.description != blank %}
      <p class="knr-what-customers__description">{{ section.settings.description }}</p>
    {% endif %}
  </div>

  <div class="knr-what-customers__compare" id="knr-compare-{{ section.id }}" data-section-id="{{ section.id }}">
    <div class="knr-compare__wrap">
      <div class="knr-compare__before">
        <span class="knr-compare__name">Before</span>
        <img
          src="{{ section.settings.before_image | image_url: width: 1600 }}"
          alt="Before"
          width="{{ section.settings.before_image.width | default: 1600 }}"
          height="{{ section.settings.before_image.height | default: 900 }}"
        >
      </div>
      <div class="knr-compare__after">
        <span class="knr-compare__name">After</span>
        <img
          src="{{ section.settings.after_image | image_url: width: 1600 }}"
          alt="After"
          width="{{ section.settings.after_image.width | default: 1600 }}"
          height="{{ section.settings.after_image.height | default: 900 }}"
        >
      </div>
      <div class="knr-compare__handle" role="slider" aria-label="Before/after slider" tabindex="0">
        <span class="knr-compare__handle-core" aria-hidden="true">
          <span class="knr-compare__handle-lines">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </span>
      </div>
    </div>
  </div>

  <div class="knr-what-customers__reviews" style="text-align: {{ section.settings.text_alignment }};">
    <slider-component class="knr-review-slider">
      <div id="Slider-{{ section.id }}" class="knr-review-list slider slider--everywhere">
        {% for block in section.blocks %}
          <div
            id="Slide-{{ block.id }}"
            class="knr-review slider__slide knr-review--{{ block.id }}"
          >
            <div class="knr-review__rating">
              <span class="stars">
                {%- for i in (1..block.settings.rating) -%}
                  ★
                {%- endfor -%}
              </span>
              <span class="knr-review__person">{{ block.settings.person }}</span>
            </div>
            <div class="knr-review__comment">{{ block.settings.comment }}</div>
          </div>
        {% endfor %}
      </div>
      {% if section.blocks.size > 1 %}
        <div class="slider-buttons knr-review-slider__controls">
          <button
            type="button"
            class="slider-button"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="icon">
              {{ 'icon-arrow-prev.svg' | inline_asset_content }}
            </span>
          </button>
          <button
            type="button"
            class="slider-button"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="icon"> {{ 'icon-arrow-next.svg' | inline_asset_content }}</span>
          </button>
        </div>
      {% endif %}
    </slider-component>
  </div>

  {% if section.settings.width_mode == 'theme' %}
    </div>
  {% endif %}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.80 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
      padding-left: {{ section.settings.padding_left | times: 0.80 | round: 0 }}px;
      padding-right: {{ section.settings.padding_right | times: 0.80 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-bottom: {{ section.settings.padding_bottom }}px;
        padding-left: {{ section.settings.padding_left }}px;
        padding-right: {{ section.settings.padding_right }}px;
      }
    }

    .knr-what-customers {
      position: relative;
    }
    .knr-what-customers__header {
      text-align: center;
      max-width: 54rem;
      margin: 0 auto 4rem;
    }
    .knr-what-customers__title {
      font-size: 4rem;
      font-weight: 400;
      letter-spacing: -1.6px;
      line-height: 4.8rem;
      margin: 0 0 1.6rem;
    }
    .knr-what-customers__description {
      color: inherit;
      font-size: 1.4rem;
      font-weight: 400;
      letter-spacing: -0.28px;
      line-height: 2.2rem;
      margin: 0;
      padding: 0;
    }
    .knr-compare__wrap {
      position: relative;
      overflow: hidden;
      max-width: 100%;
      margin: 0 auto 3.2rem;
      cursor: ew-resize;
      width: 100%;
      aspect-ratio: 2 / 1;
      height: auto;
      min-height: 19.2rem;
    }
    .knr-compare__before,
    .knr-compare__after {
      position: absolute;
      top: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }
    .knr-compare__before {
      left: 0;
    }
    .knr-compare__after {
      right: 0;
      left: 0;
      z-index: 1;
      overflow: hidden;
      clip-path: inset(0 0 0 50%);
    }
    .knr-compare__before img,
    .knr-compare__after img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 168%;
      object-fit: cover;
      object-position: center center;
      top: 61%;
      transform: translateY(-50%);
    }
    .knr-compare__name {
      position: absolute;
      top: 3.5rem;
      left: 4rem;
      color: #000;
      font-size: 1.3rem;
      z-index: 1;
      text-transform: uppercase;
    }
    .knr-compare__after .knr-compare__name {
      right: 4.5rem;
      left: initial;
    }
    .knr-compare__handle {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 64px;
      margin-left: -32px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: ew-resize;
      z-index: 10;
      touch-action: none;
      pointer-events: auto;
    }
    .knr-compare__handle::before {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 2px;
      background: rgba(255, 255, 255, 1);
      transform: translateX(-50%);
    }
    .knr-compare__handle-core {
      position: relative;
      width: 4.8rem;
      height: 4.8rem;
      background: #ffffff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
    }
    .knr-compare__handle-lines {
      display: flex;
      gap: 0.3rem;
      align-items: center;
      justify-content: center;
    }
    .knr-compare__handle-lines span {
      display: block;
      width: 0.2rem;
      height: 1.2rem;
      background: #111111;
    }
    .knr-compare__handle:hover,
    .knr-compare__handle:focus {
      outline: none;
    }
    .knr-what-customers__reviews {
      margin-top: 4rem;
    }
    .knr-review-slider {
      width: 100%;
      max-width: 105rem;
      margin: 0 auto;
    }
    .knr-review-slider .slider--everywhere {
      margin-bottom: 0;
      padding-bottom: 0;
    }
    .knr-review-list {
      display: flex;
      gap: 2rem;
      scroll-snap-type: x mandatory;
      overflow-x: auto;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 1rem;
    }
    .knr-review-list::-webkit-scrollbar {
      display: none;
    }
    .knr-review {
      min-width: 100%;
      max-width: 100%;
      scroll-snap-align: start;
      box-sizing: border-box;
    }
    {% for block in section.blocks %}
      .knr-review--{{ block.id }} {
        padding: {{ block.settings.item_spacing | times: 0 | round: 0 }}px;
      }

      @media screen and (min-width: 750px) {
        .knr-review--{{ block.id }} {
          padding: {{ block.settings.item_spacing }}px;
        }
      }
    {% endfor %}
    .knr-review-slider__controls {
      margin-top: 4rem;
      gap: 1.6rem;
    }
    .knr-review__rating {
      color: #b5a282;
      margin-bottom: 4rem;
      font-size: 1rem;
      line-height: 1.2rem;
    }
    .knr-review__rating .stars {
      font-size: 1.3rem;
      padding-left: 1px;
      width: 60px;
      display: inline-block;
    }
    .knr-review__comment {
      font-size: 3.2rem;
      line-height: 4rem;
      margin-bottom: 0;
      font-weight: 400;
      letter-spacing: -1.28px;
      padding: 0 4.5rem;
    }
    .knr-review__person {
      padding-left: 0.4rem;
      letter-spacing: -0.4px;
      color: inherit;
    }
    .knr-review-slider__controls .slider-button {
      height: 4.8rem;
      width: 4.8rem;
      padding: 0;
    }
    .knr-review-slider button.slider-button:disabled {
      opacity: 0.25;
      cursor: default;
    }
    .knr-review-slider button.slider-button svg {
      transition: transform 0.2s ease, stroke 0.2s ease;
    }
    .knr-review-slider button.slider-button:not(:disabled):hover svg {
      transform: scale(1.25);
    }
    .knr-review-slider button.slider-button:not(:disabled):hover svg path {
      stroke: #b5a282;
    }

    @media (max-width: 749px) {
      .knr-what-customers .page-width {
        padding: 0;
      }
      .knr-review__comment {
        font-size: 2.4rem;
        line-height: 3.2rem;
        letter-spacing: -0.48px;
        padding: 0 1rem;
      }
      .knr-what-customers__title {
        font-size: 3.2rem;
        line-height: 4rem;
        letter-spacing: -1.28px;
        padding: 0 4rem;
      }
      .knr-compare__wrap {
        margin: 0 auto;
      }
    }
  {%- endstyle -%}

  <script>
    (function () {
      var root = document.getElementById('knr-compare-{{ section.id }}');
      if (!root) return;
      var wrap = root.querySelector('.knr-compare__wrap');
      var after = root.querySelector('.knr-compare__after');
      var handle = root.querySelector('.knr-compare__handle');
      if (!wrap || !after || !handle) return;

      function setPos(x) {
        var rect = wrap.getBoundingClientRect();
        var pct = Math.max(0, Math.min(1, (x - rect.left) / rect.width));
        after.style.clipPath = 'inset(0 0 0 ' + pct * 100 + '%)';
        handle.style.left = pct * 100 + '%';
      }

      var dragging = false;
      handle.addEventListener('mousedown', function (e) {
        dragging = true;
        e.preventDefault();
      });
      window.addEventListener('mouseup', function () {
        dragging = false;
      });
      window.addEventListener('mousemove', function (e) {
        if (dragging) setPos(e.clientX);
      });

      handle.addEventListener(
        'touchstart',
        function (e) {
          dragging = true;
          e.preventDefault();
        },
        { passive: false }
      );
      window.addEventListener('touchend', function () {
        dragging = false;
      });
      window.addEventListener(
        'touchmove',
        function (e) {
          if (dragging && e.touches && e.touches[0]) {
            e.preventDefault();
            setPos(e.touches[0].clientX);
          }
        },
        { passive: false }
      );

      wrap.addEventListener('click', function (e) {
        if (e.target === handle) return;
        setPos(e.clientX);
      });

      handle.addEventListener('keydown', function (e) {
        var rect = wrap.getBoundingClientRect();
        var cur = parseFloat((after.style.width || '50%').replace('%', '')) || 50;
        if (e.key === 'ArrowLeft') setPos(rect.left + rect.width * Math.max(0, cur / 100 - 0.05));
        if (e.key === 'ArrowRight') setPos(rect.left + rect.width * Math.min(1, cur / 100 + 0.05));
      });
    })();
  </script>

  {% schema %}
{
  "name": "Ce que disent nos clients",
  "settings": [
    {
      "type": "select",
      "id": "width_mode",
      "label": "Width mode",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "theme", "label": "Use theme width" }
      ],
      "default": "theme"
    },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 2, "default": 40 },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40
    },
    { "type": "range", "id": "padding_left", "label": "Padding left", "min": 0, "max": 200, "step": 2, "default": 30 },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding right",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 30
    },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "text", "id": "title", "label": "Title", "default": "Ce que disent nos clientes" },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Des transformations visibles dès 4 semaines. Nos clientes témoignent d'une peau visiblement régénérée."
    },
    { "type": "image_picker", "id": "before_image", "label": "Before image" },
    { "type": "image_picker", "id": "after_image", "label": "After image" },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment for reviews",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating (1-5)", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "person", "label": "Person", "default": "Clara T." },
        {
          "type": "textarea",
          "id": "comment",
          "label": "Comment",
          "default": "J'utilise ce sérum depuis trois mois et la différence est saisissante."
        },
        {
          "type": "range",
          "id": "item_spacing",
          "label": "Item spacing (px)",
          "min": 0,
          "max": 80,
          "step": 4,
          "default": 24
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ce que disent nos clients",
      "category": "Sections",
      "blocks": [{ "type": "review" }, { "type": "review" }]
    }
  ]
}
  {% endschema %}
</section>
