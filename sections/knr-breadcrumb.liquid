{%- assign _show_home = nil -%}
{%- assign _home_label = nil -%}
{%- assign _show_collection = nil -%}
{%- assign _separator = nil -%}

{%- if show_home != nil -%}
  {%- assign _show_home = show_home -%}
{%- elsif section and section.settings and section.settings.show_home != nil -%}
  {%- assign _show_home = section.settings.show_home -%}
{%- else -%}
  {%- assign _show_home = true -%}
{%- endif -%}

{%- if home_label != nil -%}
  {%- assign _home_label = home_label -%}
{%- elsif section and section.settings and section.settings.home_label != nil -%}
  {%- assign _home_label = section.settings.home_label -%}
{%- else -%}
  {%- assign _home_label = 'Accueil' -%}
{%- endif -%}

{%- if show_collection != nil -%}
  {%- assign _show_collection = show_collection -%}
{%- elsif section and section.settings and section.settings.show_collection != nil -%}
  {%- assign _show_collection = section.settings.show_collection -%}
{%- else -%}
  {%- assign _show_collection = true -%}
{%- endif -%}

{%- if separator != nil -%}
  {%- assign _separator = separator -%}
{%- elsif section and section.settings and section.settings.separator != nil -%}
  {%- assign _separator = section.settings.separator -%}
{%- else -%}
  {%- assign _separator = '›' -%}
{%- endif -%}

<nav class="knr-breadcrumb" aria-label="{{ 'general.breadcrumbs' | t }}">
  <ol class="knr-breadcrumb__list">
    {% if _show_home %}
      <li class="knr-breadcrumb__item">
        <a class="knr-breadcrumb__link" href="{{ routes.root_url }}">{{ _home_label }}</a>
      </li>
    {% endif %}

    {% assign current_collection = collection %}
    {% if current_collection == null and product %}
      {% assign current_collection = product.collections.first %}
    {% endif %}

    {% if current_collection and _show_collection %}
      <li class="knr-breadcrumb__sep" aria-hidden="true">{{ _separator }}</li>
      <li class="knr-breadcrumb__item">
        <a class="knr-breadcrumb__link" href="{{ current_collection.url }}">{{ current_collection.title }}</a>
      </li>
    {% endif %}

    {% if product %}
      <li class="knr-breadcrumb__sep" aria-hidden="true">{{ _separator }}</li>
      <li class="knr-breadcrumb__item knr-breadcrumb__current" aria-current="page">{{ product.title }}</li>
    {% endif %}
  </ol>

  <style>
    .knr-breadcrumb { font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial; }
    .knr-breadcrumb__list { display:flex; flex-wrap:wrap; align-items:center; gap:0.5rem; list-style:none; padding:0; margin:0; font-size:0.9375rem; }
    .knr-breadcrumb__item { display:inline-flex; align-items:center; color:var(--color-foreground, #111111); }
    .knr-breadcrumb__link { color:var(--color-foreground, #111111); text-decoration:none; opacity:0.85; }
    .knr-breadcrumb__link:hover, .knr-breadcrumb__link:focus { text-decoration:underline; opacity:1; }
    .knr-breadcrumb__sep { color:var(--color-foreground, #888888); margin:0 0.25rem; }
    .knr-breadcrumb__current { color:var(--color-foreground, #111111); font-weight:600; }
    @media (max-width: 600px) { .knr-breadcrumb__list { font-size:0.875rem; gap:0.375rem; } }
  </style>
