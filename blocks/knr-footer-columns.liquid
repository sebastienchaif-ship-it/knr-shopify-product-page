{% style %}
  .knr-footer-columns {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 2rem {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    font-family: Inter, sans-serif;
  }

  .knr-footer-columns__container {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .knr-footer-columns__grid {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    gap: {{ block.settings.column_gap }}px;
  }

  .knr-footer-columns__column {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 28rem;
    width: 20%;
  }

  .knr-footer-columns__column:first-child {
    padding-left: 2rem;
  }

  .knr-footer-columns__column:nth-child(2) {
    padding-left: 1.4rem;
  }

  .knr-footer-columns__column:nth-child(3) {
    padding-left: .9rem;
  }

  .knr-footer-columns__column:last-child {
    padding-left: .4rem;
    padding-right: 1.6rem;
    max-width: 42rem;
    width: 40%;
  }

  .knr-footer-columns__menu-title,
  .knr-footer-columns__custom-title {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 400;
    margin: .1rem 0 .5rem;
    color: {{ block.settings.title_color }};
    letter-spacing: -0.375px;
  }

  .knr-footer-columns__menu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }

  .knr-footer-columns__menu-link {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_size }}px;
    letter-spacing: -0.35px;
    transition: color 0.3s ease;
  }

  .knr-footer-columns__menu-link:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .knr-footer-columns__custom-text {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: .5rem 0 1rem;
    letter-spacing: -0.35px;
  }

  .knr-footer-columns__custom-text p {
    margin: 0;
  }

  .knr-footer-columns__custom-image {
    width: 100%;
    max-width: {{ block.settings.image_width }}px;
    height: auto;
    margin-bottom: 0;
  }

  .knr-footer-columns__custom-image-placeholder {
    width: 100%;
    max-width: {{ block.settings.image_width }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    position: relative;
  }

  .knr-footer-columns__custom-image-placeholder svg {
    width: 100%;
    height: auto;
  }

  .knr-footer-columns__image-caption {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 .6rem;
    line-height: 1.4;
    letter-spacing: -0.35px;
  }

  .knr-footer-columns__cta {
    display: inline-block;
    padding: 1rem 0 1.2rem;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: underline;
    text-underline-offset: .6rem;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_text_size }}px;
    font-weight: 500;
    letter-spacing: -0.35px;
    transition: background-color 0.3s ease;
  }

  .knr-footer-columns__cta:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
  }

  @media screen and (max-width: 989px) {
    .knr-footer-columns__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media screen and (max-width: 749px) {
    .knr-footer-columns__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
{% endstyle %}

<div class="knr-footer-columns" {{ block.shopify_attributes }}>
  <div class="knr-footer-columns__container">
    <div class="knr-footer-columns__grid">
      {% for i in (1..3) %}
        {% liquid
          assign menu_key = 'menu_' | append: i
          assign menu = block.settings[menu_key]
          assign menu_title_key = 'menu_' | append: i | append: '_title'
          assign menu_title = block.settings[menu_title_key]
        %}

        <div class="knr-footer-columns__column">
          {% if menu != blank %}
            <h3 class="knr-footer-columns__menu-title">{{ menu_title | default: menu.title }}</h3>
            <ul class="knr-footer-columns__menu-list">
              {% for link in menu.links %}
                <li>
                  <a href="{{ link.url }}" class="knr-footer-columns__menu-link">
                    {{ link.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endfor %}

      <div class="knr-footer-columns__column">
        {% if block.settings.custom_title != blank %}
          <h3 class="knr-footer-columns__custom-title">{{ block.settings.custom_title }}</h3>
        {% endif %}

        {% if block.settings.custom_text != blank %}
          <div class="knr-footer-columns__custom-text">
            {{ block.settings.custom_text }}
          </div>
        {% endif %}

        {% if block.settings.custom_image != blank %}
          <img
            src="{{ block.settings.custom_image | image_url: width: 400 }}"
            alt="{{ block.settings.custom_image.alt | escape }}"
            class="knr-footer-columns__custom-image"
            loading="lazy"
            width="{{ block.settings.custom_image.width }}"
            height="{{ block.settings.custom_image.height }}"
          >
        {% else %}
          <div class="knr-footer-columns__custom-image-placeholder">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.custom_image_caption != blank %}
          <p class="knr-footer-columns__image-caption">{{ block.settings.custom_image_caption }}</p>
        {% endif %}

        {% if block.settings.cta_label != blank %}
          <a href="{{ block.settings.cta_link }}" class="knr-footer-columns__cta">
            {{ block.settings.cta_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

