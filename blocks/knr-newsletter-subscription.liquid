{%- style -%}
  .knr-newsletter-subscription {
    position: relative;
    width: 100%;
    display: block;
    font-family: Inter, sans-serif;
  }
  .knr-newsletter-subscription .page-width {
    width: 100%;
  }
  @media screen and (min-width: 750px) {
    .knr-newsletter-subscription .page-width {
      padding: 0 4rem;
    }
  }
  .knr-newsletter-subscription__inner {
    margin: 0 auto;
  }
  .knr-newsletter-subscription__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    width: 100%;
  }
  .knr-newsletter-subscription__media,
  .knr-newsletter-subscription__content {
    width: 100%;
  }
  .knr-newsletter-subscription__image-wrap {
    width: 100%;
    overflow: hidden;
    border-radius: 0;
  }
  .knr-newsletter-subscription__image-wrap img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  .knr-newsletter-subscription__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .knr-newsletter-subscription__image-placeholder svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }
  .knr-newsletter-subscription__title {
    margin: 0;
    font-weight: 400;
    letter-spacing: 0;
  }
  .knr-newsletter-subscription__form {
    margin: 0;
  }
  .knr-newsletter-subscription__field-row {
    display: flex;
    width: 100%;
    gap: 0;
  }
  .knr-newsletter-subscription__input {
    flex: 1;
    min-width: 0;
    margin: 0;
    box-sizing: border-box;
    border-radius: 0;
  }
  .knr-newsletter-subscription__button {
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.25s ease;
    border-radius: 0;
  }
  .knr-newsletter-subscription__button:hover {
    filter: brightness(0.95);
  }
  .knr-newsletter-subscription__success,
  .knr-newsletter-subscription__error,
  .knr-newsletter-subscription__gdpr {
    margin: 0;
  }
  @media screen and (max-width: 749px) {
    .knr-newsletter-subscription__grid {
      grid-template-columns: 1fr;
    }
    .knr-newsletter-subscription__field-row {
      flex-direction: column;
    }
    .knr-newsletter-subscription__button {
      width: 100%;
    }
  }
{%- endstyle -%}

<div
  id="knr-newsletter-subscription-{{ block.id }}"
  class="knr-newsletter-subscription"
  {{ block.shopify_attributes }}
>
  <div class="page-width">
    <div class="knr-newsletter-subscription__inner">
      <div class="knr-newsletter-subscription__grid">
        <div class="knr-newsletter-subscription__media">
          {% if block.settings.image %}
            <div class="knr-newsletter-subscription__image-wrap">
              <img
                src="{{ block.settings.image | image_url: width: 1400 }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            </div>
          {% else %}
            <div class="knr-newsletter-subscription__image-placeholder">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        <div class="knr-newsletter-subscription__content">
          {% if block.settings.title != blank %}
            <h2 class="knr-newsletter-subscription__title">{{ block.settings.title }}</h2>
          {% endif %}

          {%- form 'customer', class: 'knr-newsletter-subscription__form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">

            <div class="knr-newsletter-subscription__field-row">
              <input
                type="email"
                name="contact[email]"
                class="knr-newsletter-subscription__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="knr-newsletter-subscription-error-{{ block.id }}"
                {% endif %}
                {% if form.posted_successfully? %}
                  aria-describedby="knr-newsletter-subscription-success-{{ block.id }}"
                {% endif %}
                placeholder="E-mail"
                required
              >
              <button type="submit" class="knr-newsletter-subscription__button">
                {{ block.settings.button_text }}
              </button>
            </div>

            {%- if form.errors -%}
              <p id="knr-newsletter-subscription-error-{{ block.id }}" class="knr-newsletter-subscription__error">
                {{ form.errors.messages.email }}
              </p>
            {%- endif -%}

            {%- if form.posted_successfully? -%}
              <p
                id="knr-newsletter-subscription-success-{{ block.id }}"
                class="knr-newsletter-subscription__success"
              >
                {{ block.settings.success_message }}
              </p>
            {%- endif -%}
          {%- endform -%}

          {% if block.settings.gdpr_text != blank %}
            <div class="knr-newsletter-subscription__gdpr">
              {{ block.settings.gdpr_text }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #knr-newsletter-subscription-{{ block.id }} {
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__inner {
    max-width: {{ block.settings.container_width }}px;
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__grid {
    gap: {{ block.settings.grid_gap }}px;
  }
  @media (min-width: 750px) {
    #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__grid {
      justify-content: space-between;
      align-items: center;
    }
    #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__media {
      width: 68rem;
    }
    #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__image-wrap,
    #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__image-placeholder {
      width: 68rem;
      height: 54rem;
      aspect-ratio: auto;
      border-radius: 0;
    }
    #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__content {
      max-width: 63.4rem;
      width: 100%;
    }
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__image-wrap,
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__image-placeholder {
    border-radius: 0;
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__content {
    padding: {{ block.settings.content_padding }}px;
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__title {
    margin-bottom: {{ block.settings.title_margin_bottom }}px;
    font-size: 4rem;
    line-height: 4.8rem;
    letter-spacing: -0.35px;
    color: {{ block.settings.title_color }};
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__form {
    margin-bottom: {{ block.settings.form_margin_bottom }}px;
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__field-row { gap: 0; }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__input {
    padding: 0 2.2rem;
    height: 4.8rem;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: 0;
    font-size: {{ block.settings.input_font_size }}px;
    line-height: 1.2;
    color: {{ block.settings.input_text_color }};
    background-color: {{ block.settings.input_background_color }};
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__input::placeholder {
    color: {{ block.settings.input_placeholder_color }};
    font-size: 1.2rem;
    line-height: 2rem;
    font-weight: 400;
    opacity: 1;
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__button {
    width: 16rem;
    min-width: 16rem;
    height: 4.8rem;
    padding: 0 1.6rem;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: 0;
    border-radius: 0;
    font-size: 1.3rem;
    line-height: 2rem;
    letter-spacing: 0;
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__button:hover {
    background-color: {{ block.settings.button_hover_color }};
    filter: none;
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__success,
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__error {
    margin-top: 12px;
    font-size: {{ block.settings.message_font_size }}px;
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__success {
    color: {{ block.settings.success_color }};
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__error {
    color: {{ block.settings.error_color }};
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__gdpr {
    font-size: {{ block.settings.gdpr_font_size }}px;
    line-height: 1.5;
    color: {{ block.settings.gdpr_text_color }};
    margin-bottom: .2rem;
  }
  #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__gdpr p {
    font-size: 1rem;
    margin: 0;
    letter-spacing: -0.275px;
  }
  @media (max-width: 749px) {
    #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__grid {
      gap: {{ block.settings.mobile_grid_gap }}px;
    }
    #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__content {
      padding: {{ block.settings.mobile_content_padding }}px;
    }
    #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__title {
      font-size: {{ block.settings.mobile_title_font_size }}px;
      line-height: 1.2;
    }
    #knr-newsletter-subscription-{{ block.id }} .knr-newsletter-subscription__field-row { gap: {{ block.settings.mobile_input_button_gap }}px; }
  }
</style>

{% schema %}
