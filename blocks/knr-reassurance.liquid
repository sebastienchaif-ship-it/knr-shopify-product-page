{% style %}
  .knr-reassurance {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px 78px;
    margin:{{ block.settings.section_margin_top }}px  0 {{ block.settings.section_margin_bottom }}px;
    font-family: Inter, sans-serif;
  }

  .knr-reassurance__container {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .knr-reassurance__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.items_spacing }}px;
  }

  .knr-reassurance__slider-dots {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin: 0;
    padding: 0;
  }

  .knr-reassurance__slider-dots .slider-counter__link {
    padding: 0;
    margin: 0;
    line-height: 0;
  }

  .knr-reassurance__slider-dots .slider-counter__link .dot {
    width: 25px;
    height: 1px;
    border: 0;
    border-radius: 0;
    margin: 0;
    padding: 0;
    display: block;
    background-color: #B5A282;
  }

  .knr-reassurance__slider-dots .slider-counter__link--active .dot {
    background-color: #000000;
  }

  .knr-reassurance__slider-dots .slider-counter__link:not(.slider-counter__link--active):hover .dot {
    background-color: #b9b09b;
  }

  .knr-reassurance__item {
    display: flex;
    flex-direction: column;
    align-items: {% if block.settings.text_alignment == 'left' %}flex-start{% elsif block.settings.text_alignment == 'right' %}flex-end{% else %}center{% endif %};
    text-align: {{ block.settings.text_alignment }};
    gap: {{ block.settings.content_spacing }}px;
    padding: 1rem .5rem 0 .5rem;
    max-width: 16rem;
    margin: 0 auto;
  }

  .knr-reassurance__icon {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .knr-reassurance__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .knr-reassurance__icon-placeholder {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .knr-reassurance__icon-placeholder svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .knr-reassurance__content {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .knr-reassurance__title {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 400;
    color: {{ block.settings.text_color }};
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.125px;
  }

  .knr-reassurance__text {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 2rem;
    padding: 0;
    letter-spacing: -0.125px;
  }

  .knr-reassurance__text br {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .knr-reassurance {
      margin: 3.2rem 0;
      padding: 8rem 4rem;
    }

    .knr-reassurance__content {
      gap: 2.4rem;
    }

    .knr-reassurance__grid {
      display: flex;
      gap: 0;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
    }

    .knr-reassurance__grid::-webkit-scrollbar {
      display: none;
    }

    .knr-reassurance__item {
      flex: 0 0 100%;
      min-width: 100%;
      max-width: 100%;
      scroll-snap-align: start;
    }

    .knr-reassurance__text {
      margin: 0;
      line-height: 2rem;
      padding: 0;
      letter-spacing: -0.24px;
    }

    .knr-reassurance .slider-buttons {
      margin-top: 2.4rem;
    }
  }
{% endstyle %}

{%- liquid
  assign reassurance_items_count = 0
  for i in (1..6)
    assign enabled_key = 'item_' | append: i | append: '_enabled'
    if block.settings[enabled_key]
      assign reassurance_items_count = reassurance_items_count | plus: 1
    endif
  endfor
-%}

<div class="knr-reassurance" {{ block.shopify_attributes }}>
  <div class="knr-reassurance__container">
    <slider-component class="knr-reassurance__slider">
      <div id="Slider-{{ block.id }}" class="knr-reassurance__grid slider slider--mobile">
        {% for i in (1..6) %}
          {% liquid
            assign enabled_key = 'item_' | append: i | append: '_enabled'
            assign icon_key = 'item_' | append: i | append: '_icon'
            assign title_key = 'item_' | append: i | append: '_title'
            assign description_key = 'item_' | append: i | append: '_description'

            assign item_enabled = block.settings[enabled_key]
            assign item_icon = block.settings[icon_key]
            assign item_title = block.settings[title_key]
            assign item_description = block.settings[description_key]
          %}

          {% if item_enabled %}
            <div id="Slide-{{ block.id }}-{{ i }}" class="knr-reassurance__item slider__slide">
              {% if item_icon %}
                <div class="knr-reassurance__icon">
                  <img
                    src="{{ item_icon | image_url: width: 200 }}"
                    alt="{{ item_title | escape }}"
                    loading="lazy"
                    width="200"
                    height="200"
                  >
                </div>
              {% endif %}
              <div class="knr-reassurance__content">
                {% if item_title != blank %}
                  <h3 class="knr-reassurance__title">{{ item_title }}</h3>
                {% endif %}
                {% if item_description != blank %}
                  <p class="knr-reassurance__text">{{ item_description | newline_to_br }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if reassurance_items_count > 1 %}
        <div class="slider-buttons large-up-hide">
          <div
            class="slider-counter slider-counter--dots knr-reassurance__slider-dots"
            role="group"
            aria-label="{{ 'sections.slideshow.carousel' | t }}"
          >
            {%- for i in (1..reassurance_items_count) -%}
              <button
                class="slider-counter__link slider-counter__link--dots link{% if forloop.first %} slider-counter__link--active{% endif %}"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ reassurance_items_count }}"
                aria-controls="Slider-{{ block.id }}"
              >
                <span class="dot"></span>
              </button>
            {%- endfor -%}
          </div>
        </div>
      {% endif %}
    </slider-component>
  </div>
</div>

